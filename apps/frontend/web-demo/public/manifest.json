{
  "manifest_version": 3,
  "key": "",
  "name": "safe-ticket",
  "version": "0.0.0",
  "description": "Parses Joongna and Bunjang product or chat pages and posts scan payloads to the safe-ticket backend.",
  "icons": {
    "16": "icons/safe-ticket-icon-16.png",
    "32": "icons/safe-ticket-icon-32.png",
    "48": "icons/safe-ticket-icon-48.png",
    "128": "icons/safe-ticket-icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://54.180.226.121:8000/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://54.180.226.121:3000/*",
    "https://web.joongna.com/*",
    "https://m.joongna.com/*",
    "https://m.bunjang.co.kr/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/safe-ticket-icon-128.png"],
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://54.180.226.121/*",
        "https://web.joongna.com/*",
        "https://m.joongna.com/*",
        "https://m.bunjang.co.kr/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.joongna.com/*",
        "https://m.joongna.com/*",
        "https://m.bunjang.co.kr/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/safe-ticket-icon-16.png",
      "32": "icons/safe-ticket-icon-32.png",
      "48": "icons/safe-ticket-icon-48.png",
      "128": "icons/safe-ticket-icon-128.png"
    },
    "default_title": "safe-ticket",
    "default_popup": "popup.html"
  }
}
