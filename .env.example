# ===== App =====
APP_ENV=local
PROJECT_NAME=safe-ticket

# ===== Ports =====
BACKEND_PORT=8000
FRONTEND_PORT=3000
PIPELINE_PORT=8010
DB_PORT=5432
LOOKUP_BROWSER_PORT=6080

# ===== Public frontend build URLs =====
# Local Docker example:
# VITE_SAFE_TICKET_API_BASE_URL=http://localhost:8000
# VITE_SAFE_TICKET_FRONTEND_BASE_URL=http://localhost:3000
# Server deployment example:
# VITE_SAFE_TICKET_API_BASE_URL=http://<SERVER_IP_OR_DOMAIN>:8000
# VITE_SAFE_TICKET_FRONTEND_BASE_URL=http://<SERVER_IP_OR_DOMAIN>:3000
VITE_SAFE_TICKET_API_BASE_URL=http://localhost:8000
VITE_SAFE_TICKET_FRONTEND_BASE_URL=http://localhost:3000

# ===== PostgreSQL =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=safe_ticket
# SQLAlchemy + psycopg (v3) dialect
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/safe_ticket

# ===== OpenAI =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_TIMEOUT_SECONDS=8
OPENAI_MAX_RETRIES=1

# ==== Google AI Studio / Gemini ====
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_TIMEOUT_SECONDS=8

# ===== Scan / Polling =====
SCAN_PROCESSING_MODE=background
SCAN_POLL_INTERVAL_MS=2000
SCAN_POLL_TIMEOUT_MS=15000
SCAN_PARTIAL_RESULT_ENABLED=true

# ===== Pipeline =====
# Docker example: http://pipeline:8010
# Local example: http://localhost:8010
PIPELINE_BASE_URL=http://pipeline:8010
PIPELINE_ANALYZE_PATH=/api/v1/analyze
PIPELINE_TIMEOUT_SECONDS=10
PIPELINE_API_KEY=

# ===== External lookup automation =====
EXTERNAL_LOOKUP_TIMEOUT_MS=15000
THECHEAT_CDP_URL=http://lookup-browser:9223

# ===== CORS =====
# comma-separated allowlist
# Server deployment should also include http://<SERVER_IP_OR_DOMAIN>:3000.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,chrome-extension://YOUR_EXTENSION_ID

# ===== Auth (future; disabled for now) =====
PUBLIC_AUTH_ENABLED=false
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
